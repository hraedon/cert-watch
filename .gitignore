__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.coverage
coverage.json
*.sqlite3
htmlcov/
plans/design/

# Visual-regression diff artifacts (failures only). The baselines under
# tests/e2e/__screenshots__/ ARE committed — they are the source of truth.
snapshot_failures/
snapshot_tests_failures/
# Generated from the agent-notes DB (breadcrumb export-index). Ignored while it is
# refreshed manually — a committed-but-stale index lies. Commit it (remove this
# line) only once a hook regenerates it on every commit.
OPEN_WORK_ITEMS.txt

# Physical breadcrumb files are retired — regista is the source of truth.
# Tracked in the agent-notes DB; do not hand-create files here.
breadcrumbs/

# Never commit plaintext secrets. Real secrets belong in Vault / the CI secret
# store; these patterns are a backstop against an accidental `git add`.
credentials.txt
*.creds
*.secret
.env
.env.*
secrets/

# Lab / environment-specific CA and certificate material — keep out of VCS.
# The Hraedon lab root CA is supplied at deploy time, not committed.
hraedon_root.cer
*.cer

# UI-review screenshot artifacts (kimi/visual-review sessions). Transient eyeballing
# aids, not source — keep them out of an accidental `git add -A` sweep.
ui-review/
*-dark.png
*-light.png
dashboard-*.png
insights-*.png
review-*.png

# never commit the local denylist (identifier gate)
.identifiers-denylist.local
