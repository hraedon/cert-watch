<?xml version="1.0" encoding="utf-8"?>
<!--
  cert-watch on IIS via HttpPlatformHandler (recommended).

  IIS launches and supervises uvicorn as a child of the application pool and
  proxies all requests to it over a loopback port that IIS chooses
  (%HTTP_PLATFORM_PORT%). No third-party service wrapper (e.g. NSSM) is
  required — the Microsoft-signed HttpPlatformHandler module is the only
  prerequisite. See README.md in this directory for full setup.

  Place this file in the IIS site's physical path (e.g. C:\inetpub\cert-watch).
  The application code itself lives in the virtualenv created by
  scripts\install-windows.ps1 (default C:\ProgramData\cert-watch\venv).
-->
<configuration>
  <system.webServer>
    <handlers>
      <!-- Hand every request to the Python process. -->
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="C:\ProgramData\cert-watch\venv\Scripts\python.exe"
                  arguments="-m uvicorn cert_watch.app:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --proxy-headers --forwarded-allow-ips=127.0.0.1"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\ProgramData\cert-watch\logs\stdout"
                  startupTimeLimit="60"
                  startupRetryCount="3"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="CERT_WATCH_DATA_DIR" value="C:\ProgramData\cert-watch" />
        <!-- IIS supervises uvicorn on a loopback port (see arguments above:
             --host 127.0.0.1). Mirror that bind in CERT_WATCH_HOST so the
             secure-by-default startup check (BC-083) recognizes the loopback
             bind and stays exempt — IIS fronts TLS (and optionally Windows
             auth), so an auth-off app behind it is the supported default.
             uvicorn ignores this var because --host is passed explicitly. -->
        <environmentVariable name="CERT_WATCH_HOST" value="127.0.0.1" />
        <!-- IIS terminates TLS and reverse-proxies to the loopback port, so
             trust the forwarded client IP / scheme for rate limiting + cookies. -->
        <environmentVariable name="CERT_WATCH_TRUST_PROXY" value="1" />
        <!-- Signing keys are read from files written by install-windows.ps1
             (the *_FILE convention keeps secrets out of this checked-in config). -->
        <environmentVariable name="CERT_WATCH_AUTH_SECRET_FILE" value="C:\ProgramData\cert-watch\secrets\auth_secret" />
        <environmentVariable name="CERT_WATCH_CSRF_SECRET_FILE" value="C:\ProgramData\cert-watch\secrets\csrf_secret" />
        <!-- Scanning options (mirror deploy/k8s) — adjust for your network. -->
        <environmentVariable name="CERT_WATCH_ALLOW_PRIVATE_IPS" value="1" />
        <!-- Authentication is OFF until you set a provider. Uncomment to enable:
        <environmentVariable name="AUTH_PROVIDER" value="ldap" />
        <environmentVariable name="LDAP_SERVER" value="ldap://dc.example.com" />
        <environmentVariable name="LDAP_BASE_DN" value="DC=example,DC=com" />
        -->
      </environmentVariables>
    </httpPlatform>

    <!-- Don't advertise the IIS/Python stack. -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>

    <!-- HSTS + scheme awareness when IIS is the TLS terminator. -->
    <httpProtocol>
      <customHeaders>
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
